# 保留原有锁定不变
CONFIG_TARGET_ramips=y
CONFIG_TARGET_ramips_mt7621=y
CONFIG_TARGET_ramips_mt7621_DEVICE_maiwardi_w6180=y # 修正设备名，和mk统一maiwardi_w6180
CONFIG_IMAGE_SIZE="32448k"

# SPI NOR不变
CONFIG_MTD_SPI_NOR=y
CONFIG_PACKAGE_kmod-spi-nor=y
CONFIG_MTD_SPLIT_SUPPORT=y
CONFIG_MTD_SPLIT_FIRMWARE=y
CONFIG_MTD_SPLIT_UIMAGE_FW=y
# NAND全关
# CONFIG_MTD_NAND is not set
# CONFIG_PACKAGE_kmod-nand-spl is not set

# 无线驱动（mt76da闭源）
# CONFIG_PACKAGE_kmod-mt76 is not set
# CONFIG_PACKAGE_kmod-mt76-core is not set
CONFIG_PACKAGE_mtk-wifi-da=y
CONFIG_PACKAGE_mt76da-firmware=y
CONFIG_PACKAGE_kmod-mt76-connac=y

# 临时关闭硬件NAT，编译调试通过后再打开
# CONFIG_PACKAGE_kmod-mt7621-nat=y
# CONFIG_PACKAGE_flowoffload=y

# 新增：SPI Flash必备模块
CONFIG_PACKAGE_kmod-m25p80=y
